# Application settings
PORT=5050

# UniFi/UDM Pro credentials
UNIFI_ENABLED=true
UNIFI_URL=https://192.168.1.1
UNIFI_USERNAME=admin
UNIFI_PASSWORD=your_password_here
UNIFI_SITE=default

# OPNsense credentials
OPNSENSE_ENABLED=true
OPNSENSE_URL=https://192.168.254.1
OPNSENSE_API_KEY=your_api_key_here
OPNSENSE_API_SECRET=your_api_secret_here